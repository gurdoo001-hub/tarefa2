.container-left {
        width: 100%;
        height: 50%;
        padding: 0;
        margin: 0;
        align-items: center;
        text-align: center;
        display: block;

    }

    .container-right {
        width: 100%;
        margin: 0 auto;
        justify-content: center;
        height: 78%;
        display: grid;
        position: unset;
        grid-auto-flow: row;
        align-content: start;
        align-items: baseline;
        justify-items: center;
    }

    header {
        display: none;
    }